# Modelo de variáveis de ambiente. Copie para ".env" e preencha.
# NUNCA comite o arquivo ".env" real (ele contém segredos).

# Banco de dados.
# Local (desenvolvimento) — SQLite em arquivo:
DATABASE_URL="file:./dev.db"
# Produção (nuvem) — PostgreSQL (ex.: Neon, Supabase, Railway):
# DATABASE_URL="postgresql://usuario:senha@host:5432/banco?schema=public"

# Segredo para assinar a sessão (login). Gere uma string longa e aleatória.
# Ex. para gerar: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-por-uma-string-longa-e-aleatoria"

# (Opcional) Refino de texto por IA. Sem chave, usa o gerador determinístico.
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-6"
